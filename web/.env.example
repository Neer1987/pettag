# PetTag finder web app (QR profile pages for non-app visitors)
# Copy to web/.env and fill in values (same Supabase project as the mobile app)

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Public site URL (used in meta tags; optional locally)
VITE_WEB_URL=https://pettag.app

# Optional — notify pet owners via Expo push when a finder sends a message
# VITE_EXPO_ACCESS_TOKEN=

# App download links shown on profile pages
VITE_IOS_APP_URL=https://apps.apple.com/app/pettag
VITE_ANDROID_APP_URL=https://play.google.com/store/apps/details?id=app.pettag
