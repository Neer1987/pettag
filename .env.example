# PetTag environment variables
# Copy this file to .env and fill in your values, then restart Expo with: npx expo start -c

# Public web URL encoded in QR codes — deploy the separate finder web app in /web
# Production: https://pettag.app (Vercel project root directory: web)
# Local web dev: cd web && npm run dev  →  http://localhost:5173
EXPO_PUBLIC_WEB_URL=http://localhost:5173/

# Supabase — required (app will show a setup screen until these are set)
#
# 1. Create a project at https://supabase.com
# 2. Settings → API → copy Project URL and anon public key below
# 3. SQL Editor → run in order:
#    - supabase/migrations/001_initial_schema.sql
#    - supabase/migrations/002_storage.sql
#    - supabase/migrations/004_nearby_alerts.sql
#
# Optional — Expo push (production builds via EAS):
# EXPO_PUBLIC_EXPO_ACCESS_TOKEN=your_expo_access_token
# Deploy edge function: supabase functions deploy send-lost-pet-push
# 4. Restart Expo
#
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
